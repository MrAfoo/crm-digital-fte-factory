# NovaDeskAI Environment Variables
# Copy this file to .env and fill in your values

# ── Groq (required) ─────────────────────────────────────────
# Get free API key at: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# ── WhatsApp Cloud API (Meta — free) ────────────────────────
# Setup guide: setup/whatsapp-setup.md
# Get from: https://developers.facebook.com → Your App → WhatsApp → API Setup
WHATSAPP_TOKEN=EAAxxxxx_your_token_here
WHATSAPP_PHONE_NUMBER_ID=123456789012345
WHATSAPP_VERIFY_TOKEN=novadesk_verify

# ── Gmail API (Google Cloud Console) ────────────────────────
# Setup guide: setup/gmail-setup.md
# Step 1: python setup/gmail_oauth.py
# Step 2: python setup/gmail_watch.py
GMAIL_CREDENTIALS_PATH=setup/gmail_credentials.json
GMAIL_TOKEN_PATH=setup/gmail_token.json
GMAIL_PUBSUB_TOPIC=projects/YOUR_PROJECT_ID/topics/novadesk-gmail-notifications
GMAIL_USER_ID=me

# ── PostgreSQL (production database) ────────────────────────
# Used by Stage 2 production system
# docker-compose up postgres  (or use existing instance)
DATABASE_URL=postgresql://nova:novasecret@localhost:5432/novadesk
POSTGRES_PASSWORD=novasecret

# ── Kafka ────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_CONSUMER_GROUP=nova-agent-group

# ── API Settings ─────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
MCP_PORT=8001
API_BASE_URL=http://localhost:8000

# ── Logging ──────────────────────────────────────────────────
LOG_LEVEL=INFO
